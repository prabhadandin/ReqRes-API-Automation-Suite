      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "pm.test(\"Response time is less than 1200ms\", function () {\r",
          "    pm.expect(pm.response.responseTime).to.be.below(1200);\r",
          "});\r",
          ""
        ]
