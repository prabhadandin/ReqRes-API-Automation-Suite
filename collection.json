  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "const scenario = pm.iterationData.get(\"Scenario\");\r",
          "const folderPath = pm.execution.location; // Returns folder hierarchy\r",
          "\r",
          "// 1. Logic for authflow folder\r",
          "if (folderPath.includes(\"Auth-flows\")) {\r",
          "    // Everything in this folder runs as it's testing different login states\r",
          "    console.log(`Running login test for: ${scenario}`);\r",
          "}\r",
          "\r",
          "// 2. Logic for usermanagement folder (create, update, delete)\r",
          "if (folderPath.includes(\"User-Management\")) {\r",
          "    // Skip these requests if the current CSV row is for a failed login\r",
          "    if (scenario === \"Error_Invalid_User\" || scenario === \"Error_Missing_Password\") {\r",
          "        console.log(`Skipping management action [${pm.info.requestName}] because login failed.`);\r",
          "        pm.execution.skipRequest();\r",
          "    }\r",
          "}\r",
          ""
        ]
      }
    },
