    {
      "name": "Auth-Flows",
      "item": [
        {
          "name": "Login (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Parse response once\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// 2. Validate response before doing anything else\r",
                  "pm.test(\"Login Successful - 200 OK\", function () {\r",
                  "pm.response.to.have.status(200);\r",
                  "pm.expect(jsonData).to.have.property('token');\r",
                  "    \r",
                  "    // 3. Set environment variable only if test passes\r",
                  "    pm.environment.set(\"session_token\", jsonData.token);\r",
                  "    console.log(\"Login Success: Token saved.\");\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "user-agent": true,
              "accept": true
            }
          },
