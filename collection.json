        {
          "name": "Login (User Not Found)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const expectedStatus = Number(pm.iterationData.get(\"expected_status\")) || 400;\r",
                  "const expectedError = pm.iterationData.get(\"expected_error\"); // Add this column to your CSV\r",
                  "\r",
                  "pm.test(`Status code is ${pm.response.code}`, function () {\r",
                  "    pm.response.to.have.status(expectedStatus);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 400) {\r",
                  "    const response = pm.response.json();\r",
                  "    \r",
                  "    pm.test(`Error message matches: ${expectedError || 'user not found'}`, function () {\r",
                  "        // Fallback to \"user not found\" if CSV cell is empty\r",
                  "        pm.expect(response.error).to.eql(expectedError || \"user not found\");\r",
                  "    });\r",
                  "\r",
                  "    pm.environment.unset(\"session_token\");\r",
                  "    console.log(`Negative Test Passed: ${response.error}`);\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
