    {
      "name": "User-Management",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "const expectedStatus = parseInt(pm.iterationData.get(\"expected_create_status\")) || 201;\r",
                  "\r",
                  "// 1. Dynamic status check (covers both success and failure cases)\r",
                  "pm.test(`Status is ${pm.response.code} (Expected ${expectedStatus})`, () => {\r",
                  "    pm.response.to.have.status(expectedStatus);\r",
                  "});\r",
                  "\r",
                  "// 2. Only run Success Logic if the status is 201\r",
                  "if (pm.response.code === 201) {\r",
                  "    pm.test(\"Response contains User ID\", function () {\r",
                  "        pm.expect(response.id).to.not.be.null;\r",
                  "        pm.expect(response.id).to.not.be.undefined;\r",
                  "    });\r",
                  "\r",
                  "    // Save ID for the next steps (Update/Delete)\r",
                  "    pm.environment.set(\"new_user_id\", response.id);\r",
                  "    console.log(\"User Created: ID \" + response.id + \" saved.\");\r",
                  "} else {\r",
                  "    console.log(\"User not created. Skipping ID environment set.\");\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Verify the session token exists in the environment\r",
                  "const token = pm.environment.get(\"session_token\");\r",
                  "const userId = pm.environment.get(\"new_user_id\");\r",
                  "if (!token || token === \"{{session_token}}\") {\r",
                  "console.error(\"STOP: The session_token is empty or unresolved. Fix Login first.\");\r",
                  "pm.execution.skipRequest();\r",
                  "} else {\r",
                  "console.log(\"Auth Verified: Sending update with valid token.\");\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\"name\": \"{{name}}\",\n\"job\": \"{{job}}\"\n}\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(`Status 200: Updated to ${pm.iterationData.get(\"updated_job\")}`,function () {\r",
                  "pm.response.to.have.status(200);\r",
                  "// Validate the update actually happened using the CSV data\r",
                  "pm.expect(pm.response.json().job).to.eql(pm.iterationData.get(\"updated_job\"));\r",
                  "});\r",
                  "// Check the Performance\r",
                  "pm.test(\"Response time is less than 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Verify the session token exists in the environment\r",
                  "const token = pm.environment.get(\"session_token\");\r",
                  "const userId = pm.environment.get(\"new_user_id\");\r",
                  "if (!token || token === \"{{session_token}}\") {\r",
                  "console.error(\"STOP: The session_token is empty or unresolved. Fix Login first.\");\r",
                  "pm.execution.skipRequest();\r",
                  "} else {\r",
                  "console.log(\"Auth Verified: Sending update with valid token.\");\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {}
          },
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{session_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"{{name}}\",\r\n \"job\": \"{{updated_job}}\"\r\n }"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{new_user_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{new_user_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Get expected status from CSV (usually 204 for ReqRes Delete)\r",
                  "const expectedStatus = Number(pm.iterationData.get(\"expected_delete_status\")) || 204;\r",
                  "pm.test(`Status code is ${expectedStatus} - User Deleted`, function () {\r",
                  "pm.response.to.have.status(expectedStatus);\r",
                  "});\r",
                  "//Clear the ID so it doesn't leak into the next CSV row\r",
                  "pm.environment.unset(\"new_user_id\");\r",
                  "console.log(\"CLEANUP: User ID unset from environment.\");\r",
                  "// Check the Performance\r",
                  "pm.test(\"Response time is less than 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get(\"session_token\");\r",
                  "if (!token || token === \"{{session_token}}\") {\r",
                  "    console.error(\"STOP: The session_token is empty or unresolved. Fix Login first.\");\r",
                  "    pm.execution.skipRequest();\r",
                  "} else {\r",
                  "    console.log(\"Auth Verified: Sending DELETE with valid token.\");\r",
                  "}\r",
                  "// Ensure User ID from the 'Create' step\r",
                  "const userId = pm.environment.get(\"new_user_id\");\r",
                  "if (!userId) {\r",
                  "console.warn(\"SKIP DELETE: No 'new_user_id' found in environment for this iteration.\");\r",
                  "pm.execution.skipRequest();\r",
                  "} else {\r",
                  "console.log(`EXECUTION: Deleting User ID ${userId} as defined in ${pm.iterationData.get(\"scenario\")}`);\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{session_token}}",
                  "type": "string"
