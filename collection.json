        {
          "name": "Login (Missing Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const expectedStatus = Number(pm.iterationData.get(\"expected_status\")) || 400;\r",
                  "\r",
                  "pm.test(`Status is ${pm.response.code} (Expected ${expectedStatus})`, function () {\r",
                  "    pm.response.to.have.status(expectedStatus);\r",
                  "});\r",
                  "\r",
                  "// Only attempt to parse and check errors if the status matches a failure case\r",
                  "if (pm.response.code === 400) {\r",
                  "    try {\r",
                  "        const responseData = pm.response.json();\r",
                  "        const errorMsg = responseData.error;\r",
                  "\r",
                  "        pm.test(`Error message validation: ${errorMsg}`, function () {\r",
                  "            pm.expect(errorMsg).to.be.oneOf([\"Missing password\", \"user not found\", \"Note: Only defined users succeed\"]);\r",
                  "        });\r",
                  "    } catch (e) {\r",
                  "        console.error(\"Response was not valid JSON\");\r",
                  "    }\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\"email\": \"{{email}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
