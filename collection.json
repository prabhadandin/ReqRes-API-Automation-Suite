        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "// 1. Get data from your CSV\r",
              "const scenario = pm.iterationData.get(\"Scenario\");\r",
              "const originalName = pm.info.requestName;\r",
              "\r",
              "// 2. Update the request name for the execution report\r",
              "// This changes how it appears in the Collection Runner/Newman\r",
              "if (scenario) {\r",
              "    pm.request.name = `${scenario} | ${originalName}`;\r",
              "}\r",
              "\r",
              "// 3. Optional: Log the change for debugging\r",
              "console.log(`Executing: ${pm.request.name}`);\r",
              ""
            ]
          }
