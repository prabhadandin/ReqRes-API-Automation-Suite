    {
      "name": "User-Management",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('User Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "    pm.expect(res.id).to.exist;",
                  "});",
                  "",
                  "pm.environment.set('new_user_id', res.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"job\": \"{{job}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          }
        },
        {
          "name": "Update User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('User Updated', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(res.job).to.eql(pm.iterationData.get('updated_job'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"job\": \"{{updated_job}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{new_user_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{new_user_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User Deleted', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "pm.environment.unset('new_user_id');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{new_user_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{new_user_id}}"
              ]
            }
          }
        }
      ]
    }
